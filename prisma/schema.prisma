generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user") // "user", "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  logs     SessionLog[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("session")
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  eventType String?
  message   String   @db.Text
  status    String   @default("beklemede") // "beklemede", "cevaplandı", "iptal"
  note      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("inquiry")
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  date          DateTime?
  eventType     String   @default("diğer")
  firstName     String
  lastName      String
  phone         String
  price         String   @default("")
  deposit       String   @default("")
  paymentStatus String   @default("beklemede")
  reminderDays  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([paymentStatus])
  @@map("event")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  size      Int      @default(0)
  title     String?
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("galleryimage")
}

model Content {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.LongText

  @@index([key])
  @@map("content")
}

model Stat {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.LongText

  @@index([key])
  @@map("stat")
}

model SessionLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String
  status    String
  loginTime DateTime @default(now())

  @@index([loginTime])
  @@index([status])
  @@index([username])
  @@map("sessionlog")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String   @db.Text
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@map("project")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String   @db.Text
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@map("service")
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  quote       String   @db.Text
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@map("testimonial")
}
